{
  "name": "harness",
  "version": "1.0.0",
  "description": "Save 60-70% of Claude Code input tokens by compiling minimal context instead of full CLAUDE.md",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./cli": "./dist/cli.js"
  },
  "bin": {
    "harness": "./dist/cli.js"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/lcosent/harness.git"
  },
  "bugs": {
    "url": "https://github.com/lcosent/harness/issues"
  },
  "homepage": "https://github.com/lcosent/harness#readme",
  "scripts": {
    "build": "tsc",
    "test": "npm run test:m1 && npm run test:m2 && npm run test:m3 && npm run test:m4 && npm run test:m5 && npm run test:m6 && npm run test:m7 && npm run test:m8 && npm run test:m10 && npm run test:m11 && npm run test:m12 && npm run test:m13 && npm run test:m14 && npm run test:m16 && npm run test:m17 && npm run test:m18 && npm run test:m19",
    "test:m0": "tsx src/run.ts hello && tsx src/run.ts always-fail || true",
    "test:m1": "tsx src/m1-test.ts",
    "test:m2": "tsx src/m2-test.ts",
    "test:m3": "tsx src/m3-test.ts",
    "test:m4": "tsx src/m4-test.ts",
    "test:m5": "tsx src/m5-test.ts",
    "test:m6": "tsx src/m6-test.ts",
    "test:m7": "tsx src/m7-test.ts",
    "test:m8": "tsx src/m8-test.ts",
    "test:m10": "tsx src/m10-test.ts",
    "test:m11": "tsx src/m11-test.ts",
    "test:m12": "tsx src/m12-test.ts",
    "prepublishOnly": "npm run build",
    "test:m13": "tsx src/m13-test.ts",
    "test:m14": "tsx src/m14-test.ts",
    "test:m16": "tsx src/m16-test.ts",
    "test:m17": "tsx src/m17-test.ts",
    "test:m18": "tsx src/m18-test.ts",
    "test:m19": "tsx src/m19-test.ts"
  },
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "llm",
    "tokens",
    "optimization",
    "context-compilation",
    "orchestration",
    "anthropic",
    "productivity",
    "cost-savings"
  ],
  "author": "Luca",
  "license": "MIT",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "CHANGELOG.md"
  ],
  "type": "commonjs",
  "dependencies": {
    "gpt-tokenizer": "^3.4.0",
    "tsx": "^4.22.5",
    "typescript": "^6.0.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.0"
  }
}
